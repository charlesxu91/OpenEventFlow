{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "self": {
    "vendor": "io.openeventflow",
    "name": "product_clicked",
    "format": "jsonschema",
    "version": "1-0-0"
  },
  "type": "object",
  "description": "A user clicked a product card or product entry point.",
  "additionalProperties": false,
  "properties": {
    "product_id": {
      "type": "string",
      "description": "Stable product identifier."
    },
    "page": {
      "type": "string",
      "description": "Logical page name."
    },
    "position": {
      "type": "integer",
      "description": "Zero-based item position in the container."
    },
    "click_id": {
      "type": "string",
      "description": "Client-generated id for click deduplication."
    },
    "recommend_trace_id": {
      "type": "string",
      "description": "Recommendation request trace id."
    },
    "request_id": {
      "type": "string",
      "description": "Recommendation request identifier."
    },
    "impression_id": {
      "type": "string",
      "description": "Stable attribution identifier."
    },
    "delivery_id": {
      "type": "string",
      "description": "Related server delivery identifier."
    },
    "sku_id": {
      "type": "string",
      "description": "Stable SKU identifier."
    },
    "surface": {
      "type": "string",
      "description": "Recommendation surface."
    },
    "candidate_source": {
      "type": "string",
      "description": "Candidate generator."
    },
    "model_version": {
      "type": "string",
      "description": "Online model version."
    },
    "feature_set_version": {
      "type": "string",
      "description": "Online feature-set version."
    },
    "experiment_id": {
      "type": "string",
      "description": "Experiment identifier."
    },
    "experiment_treatment": {
      "type": "string",
      "description": "Experiment treatment."
    },
    "recommendation_generation": {
      "type": "string",
      "description": "Refresh generation identifier."
    }
  },
  "required": [
    "product_id",
    "page",
    "position",
    "click_id"
  ]
}
