{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "self": {
    "vendor": "io.openeventflow",
    "name": "order_cancelled",
    "format": "jsonschema",
    "version": "1-0-0"
  },
  "type": "object",
  "description": "The authoritative order service cancelled an order line.",
  "additionalProperties": false,
  "properties": {
    "cancellation_id": {
      "type": "string",
      "description": "Idempotency identifier for cancellation."
    },
    "order_id": {
      "type": "string",
      "description": "Authoritative order identifier."
    },
    "order_line_id": {
      "type": "string",
      "description": "Authoritative order-line identifier."
    },
    "product_id": {
      "type": "string",
      "description": "Stable product identifier."
    },
    "sku_id": {
      "type": "string",
      "description": "Stable SKU identifier."
    },
    "quantity": {
      "type": "integer",
      "description": "Cancelled quantity."
    },
    "reason": {
      "type": "string",
      "description": "Cancellation reason code."
    },
    "request_id": {
      "type": "string",
      "description": "Attributed recommendation request."
    },
    "impression_id": {
      "type": "string",
      "description": "Attributed recommendation impression."
    },
    "delivery_id": {
      "type": "string",
      "description": "Attributed delivery identifier."
    }
  },
  "required": [
    "cancellation_id",
    "order_id",
    "order_line_id",
    "product_id",
    "sku_id",
    "quantity"
  ]
}
