{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "self": {
    "vendor": "io.openeventflow",
    "name": "favorite_added",
    "format": "jsonschema",
    "version": "1-0-0"
  },
  "type": "object",
  "description": "A user added a recommended product to favorites.",
  "additionalProperties": false,
  "properties": {
    "favorite_id": {
      "type": "string",
      "description": "Idempotency identifier for the favorite action."
    },
    "product_id": {
      "type": "string",
      "description": "Stable product identifier."
    },
    "sku_id": {
      "type": "string",
      "description": "Stable SKU identifier."
    },
    "request_id": {
      "type": "string",
      "description": "Recommendation request identifier."
    },
    "impression_id": {
      "type": "string",
      "description": "Stable attribution identifier."
    },
    "delivery_id": {
      "type": "string",
      "description": "Related server delivery identifier."
    },
    "surface": {
      "type": "string",
      "description": "Recommendation surface."
    },
    "position": {
      "type": "integer",
      "description": "Zero-based ranked position."
    },
    "candidate_source": {
      "type": "string",
      "description": "Candidate generator."
    },
    "model_version": {
      "type": "string",
      "description": "Online model version."
    },
    "feature_set_version": {
      "type": "string",
      "description": "Online feature-set version."
    },
    "experiment_id": {
      "type": "string",
      "description": "Experiment identifier."
    },
    "experiment_treatment": {
      "type": "string",
      "description": "Experiment treatment."
    },
    "recommendation_generation": {
      "type": "string",
      "description": "Refresh generation identifier."
    }
  },
  "required": [
    "favorite_id",
    "product_id"
  ]
}
