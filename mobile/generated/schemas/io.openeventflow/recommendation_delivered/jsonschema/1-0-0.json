{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "self": {
    "vendor": "io.openeventflow",
    "name": "recommendation_delivered",
    "format": "jsonschema",
    "version": "1-0-0"
  },
  "type": "object",
  "description": "The recommendation service delivered a ranked product to a client.",
  "additionalProperties": false,
  "properties": {
    "delivery_id": {
      "type": "string",
      "description": "Unique server-generated delivery identifier."
    },
    "request_id": {
      "type": "string",
      "description": "Recommendation request identifier."
    },
    "impression_id": {
      "type": "string",
      "description": "Stable attribution identifier for this recommendation item."
    },
    "product_id": {
      "type": "string",
      "description": "Stable product identifier."
    },
    "sku_id": {
      "type": "string",
      "description": "Stable SKU identifier when ranking occurs at SKU level."
    },
    "surface": {
      "type": "string",
      "description": "Recommendation surface."
    },
    "position": {
      "type": "integer",
      "description": "Zero-based ranked position."
    },
    "candidate_source": {
      "type": "string",
      "description": "Candidate generator responsible for the item."
    },
    "model_version": {
      "type": "string",
      "description": "Online ranking model version."
    },
    "feature_set_version": {
      "type": "string",
      "description": "Online feature-set version."
    },
    "experiment_id": {
      "type": "string",
      "description": "Experiment identifier."
    },
    "experiment_treatment": {
      "type": "string",
      "description": "Assigned experiment treatment."
    },
    "recommendation_generation": {
      "type": "string",
      "description": "Generation identifier used to distinguish refreshes."
    }
  },
  "required": [
    "delivery_id",
    "request_id",
    "impression_id",
    "product_id",
    "surface",
    "position"
  ]
}
