{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "self": {
    "vendor": "io.openeventflow",
    "name": "add_to_cart",
    "format": "jsonschema",
    "version": "1-0-0"
  },
  "type": "object",
  "description": "A user added a product to cart.",
  "additionalProperties": false,
  "properties": {
    "product_id": {
      "type": "string",
      "description": "Stable product identifier."
    },
    "sku_id": {
      "type": "string",
      "description": "Stable SKU identifier."
    },
    "quantity": {
      "type": "integer",
      "description": "Number of units added."
    },
    "price": {
      "type": "number",
      "description": "Unit price at the time of add-to-cart."
    },
    "currency": {
      "type": "string",
      "description": "ISO currency code."
    }
  },
  "required": [
    "product_id",
    "sku_id",
    "quantity"
  ]
}
